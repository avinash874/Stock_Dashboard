# --- Local dev (npm run dev) ---
# Leave VITE_API_BASE empty: Vite proxies /companies, /data, … to http://127.0.0.1:8000
VITE_API_BASE=

# --- Production / Vercel build ---
# Backend (FastAPI on Render):
# VITE_API_BASE=https://stock-dashboard-1-0qoi.onrender.com
# (Same value is the default in src/services/config.js if this is unset.)

# Footer “Live app” link (your Vercel UI), optional:
# VITE_APP_LIVE_URL=https://stock-dashboard-tawny-nine.vercel.app
